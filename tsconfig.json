{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "types": ["node", "jest"],
    "allowJs": false,
    "checkJs": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "strict": false,
    "verbatimModuleSyntax": true,
    "isolatedModules": true
  },
  "include": ["api/**/*.ts", "src/**/*.ts", "jest.config.js"],
  "exclude": ["node_modules"]
}
